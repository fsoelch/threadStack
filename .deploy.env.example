# Server-Verbindung
DEPLOY_HOST=mein-server.de         # Hostname oder IP
DEPLOY_PORT=22                      # SSH-Port (Standard: 22)

# Benutzer wird beim Aufruf übergeben: ./deploy.sh <benutzer>
DEPLOY_PATH=/var/www/personly       # Zielverzeichnis auf dem Server

# App-Konfiguration
APP_PORT=3000                       # Node.js Port
BASE_PATH=/notes                    # URL-Pfad, z. B. /notes → http://server/notes

# Systemd-Service
SERVICE_NAME=personly               # Name des systemd-Service
